<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.control.ScrollPane?>

<StackPane fx:id="placeHolder" styleClass="pane-with-border" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <ScrollPane fx:id="scrollPane" fitToWidth="true" styleClass="result-display-scroll">
    <TextFlow fx:id="resultDisplay" styleClass="result-display-flow" />
  </ScrollPane>
</StackPane>
